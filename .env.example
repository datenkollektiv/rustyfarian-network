# WiFi Configuration
# Copy this file to .env and fill in your credentials
WIFI_SSID=your_wifi_ssid
WIFI_PASS=your_wifi_password

# MQTT Configuration
MQTT_HOST=your_mqtt_broker_host
MQTT_PORT=1883
# MQTT client ID must not exceed the 23-byte MQTT 3.1.1 maximum
MQTT_CLIENT_ID=your_mqtt_client_id

# LoRaWAN OTAA credentials (fill in from TTN/Chirpstack after device registration)
# DevEUI and AppEUI must be MSB-first as shown in TTN Console (example reverses internally)
# AppKey stays MSB-first
# LORAWAN_DEV_EUI=0000000000000000
# LORAWAN_APP_EUI=0000000000000000
# LORAWAN_APP_KEY=A14...32F
